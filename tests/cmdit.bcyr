# cmdit benchmarks — characterizes the real per-invocation cost of the parser.
# Build/run:  cyrius build tests/cmdit.bcyr build/cmdit-bench && ./build/cmdit-bench
#
# cmdit is a stdlib-only project (no external [deps.X]), so `cyrius build` does NOT
# auto-prepend stdlib — the entry includes what it uses explicitly (like smoke/test).
#
# Methodology (see docs/benchmarks.md):
#   parse-loop cost  = parse_argv_mixed.avg - setup_baseline.avg
#   register cost    = setup_baseline.avg   - cmdit_new_floor.avg
#   single-pass proof: dispatch_after_verb.avg ~= dispatch_before_verb.avg
# cmdit_new allocs ~7.8 KB into a free-less bump allocator, so the alloc-heavy
# benches run a bounded 4096 iters (~32 MB), not a 1e6 loop; the pure leaves
# (get_enum, dispatch) run high iteration counts to amortize the ~240ns clock pair.
include "lib/vec.cyr"
include "lib/args.cyr"      # pulls alloc + syscalls (alloc_init / the synthetic argv arrays)
include "lib/string.cyr"
include "lib/fmt.cyr"       # bench_report number formatting
include "lib/io.cyr"
include "lib/bench.cyr"
include "src/cmdit.cyr"

var BOUND = 4096;           # alloc-heavy bench iters (fresh ~7.8KB handle each)
var HOT = 1000000;          # pure-leaf bench iters (no per-iter alloc)
var DISP = 200000;          # dispatch bench iters (~40B remainder alloc each)

fn main(): i64 {
    alloc_init();

    # 1. cmdit_new_floor — the fixed per-handle construction floor (alloc + the
    #    6656-byte entry memzero + 2 auto registrations). Dominant term below.
    var b1 = bench_new("cmdit_new_floor");
    bench_batch_start(b1);
    var i1 = 0;
    while (i1 < BOUND) { cmdit_new("b"); i1 = i1 + 1; }
    bench_batch_stop(b1, BOUND);
    bench_report(b1);

    # 2. setup_baseline — new + register the representative flag set, NO parse.
    #    Subtract from #3 to isolate the parse loop; from #1 to isolate register cost.
    var b2 = bench_new("setup_baseline");
    bench_batch_start(b2);
    var i2 = 0;
    while (i2 < BOUND) {
        var h = cmdit_new("b");
        cmdit_bool(h, 0, "loud", "");
        cmdit_int(h, 99, "count", 1, "");
        cmdit_str(h, 110, "name", 0, "");
        cmdit_enum(h, 0, "color", "auto", "auto|always|never", "");
        i2 = i2 + 1;
    }
    bench_batch_stop(b2, BOUND);
    bench_report(b2);

    # 3. parse_argv_mixed — the hot path: parse a representative argv exercising
    #    every token shape (long bool, short int+space, long str =value, enum,
    #    two positionals). Fresh handle each iter (parse mutates the handle).
    var av = alloc(9 * 8);
    store64(av + 0 * 8, "prog"); store64(av + 1 * 8, "--loud"); store64(av + 2 * 8, "-c");
    store64(av + 3 * 8, "5"); store64(av + 4 * 8, "--name=bob"); store64(av + 5 * 8, "--color");
    store64(av + 6 * 8, "always"); store64(av + 7 * 8, "f1"); store64(av + 8 * 8, "f2");
    var b3 = bench_new("parse_argv_mixed");
    bench_batch_start(b3);
    var i3 = 0;
    while (i3 < BOUND) {
        var h3 = cmdit_new("b");
        cmdit_bool(h3, 0, "loud", "");
        cmdit_int(h3, 99, "count", 1, "");
        cmdit_str(h3, 110, "name", 0, "");
        cmdit_enum(h3, 0, "color", "auto", "auto|always|never", "");
        cmdit_parse_argv(h3, 9, av);
        i3 = i3 + 1;
    }
    bench_batch_stop(b3, BOUND);
    bench_report(b3);

    # 4. get_enum_rewalk — the pure '|'-delimited choice scan re-walked on every
    #    cmdit_get_enum call (worst case = the last choice). No per-iter alloc.
    var he = cmdit_new("t");
    var fe = cmdit_enum(he, 0, "color", "auto", "auto|always|never", "");
    var ave = alloc(3 * 8); store64(ave, "p"); store64(ave + 8, "--color"); store64(ave + 16, "never");
    cmdit_parse_argv(he, 3, ave);
    var b4 = bench_new("get_enum_rewalk");
    bench_batch_start(b4);
    var i4 = 0;
    while (i4 < HOT) { cmdit_get_enum(he, fe); i4 = i4 + 1; }
    bench_batch_stop(b4, HOT);
    bench_report(b4);

    # 5. dispatch_before_verb — single-pass dispatch with the global flag BEFORE
    #    the verb (global resolve + verb-table scan + remainder compaction).
    var hd = cmdit_new("tool");
    cmdit_bool(hd, 0, "verbose", "");
    cmdit_verb(hd, "add", ""); cmdit_verb(hd, "remove", "");
    var avb = alloc(4 * 8); store64(avb, "tool"); store64(avb + 8, "--verbose"); store64(avb + 16, "add"); store64(avb + 24, "x");
    var b5 = bench_new("dispatch_before_verb");
    bench_batch_start(b5);
    var i5 = 0;
    while (i5 < DISP) { cmdit_dispatch_argv(hd, 4, avb); i5 = i5 + 1; }
    bench_batch_stop(b5, DISP);
    bench_report(b5);

    # 6. dispatch_after_verb — same, global AFTER the verb. Should ~equal #5 (the
    #    payoff of resolving before-OR-after in ONE pass; a 2-scan impl would be ~2x).
    var ava = alloc(4 * 8); store64(ava, "tool"); store64(ava + 8, "add"); store64(ava + 16, "--verbose"); store64(ava + 24, "x");
    var b6 = bench_new("dispatch_after_verb");
    bench_batch_start(b6);
    var i6 = 0;
    while (i6 < DISP) { cmdit_dispatch_argv(hd, 4, ava); i6 = i6 + 1; }
    bench_batch_stop(b6, DISP);
    bench_report(b6);

    # 7. repeat_accumulate — N=32 -H occurrences: lazy list alloc on first, O(1)
    #    push thereafter. Fresh handle each iter (the list is per-flag mutable state).
    var avr = alloc((1 + 32 * 2) * 8);
    store64(avr, "p");
    var rk = 0;
    while (rk < 32) { store64(avr + (1 + rk * 2) * 8, "-H"); store64(avr + (2 + rk * 2) * 8, "v"); rk = rk + 1; }
    var b7 = bench_new("repeat_accumulate_32");
    bench_batch_start(b7);
    var i7 = 0;
    while (i7 < BOUND) {
        var h7 = cmdit_new("b");
        cmdit_repeat(h7, 72, "header", "");
        cmdit_parse_argv(h7, 1 + 32 * 2, avr);
        i7 = i7 + 1;
    }
    bench_batch_stop(b7, BOUND);
    bench_report(b7);

    return 0;
}

fn _entry(): i64 { var r = main(); sys_exit(r); return 0; }
_entry();
